# ============================================
# 七牛云 CDN SSL 证书自动续期配置
# ============================================

# 域名配置
DOMAIN=buildbuffer.cdn.zuoxueba.org
EMAIL=your-email@example.com

# 七牛云配置
# 获取地址: https://portal.qiniu.com/user/key
QINIU_AK=your_qiniu_access_key
QINIU_SK=your_qiniu_secret_key

# DNS 验证配置
# 根据你的 DNS 服务商选择对应的 DNS_API 和凭证
# 可选值: dns_dp, dns_ali, dns_cf, dns_cx, dns_gd 等
DNS_API=dns_dp

# DNSPod 配置 (DNS_API=dns_dp 时需要)
# 获取地址: https://console.dnspod.cn/account/token/apikey
DP_Id=your_dnspod_id
DP_Key=your_dnspod_key

# 阿里云配置 (DNS_API=dns_ali 时需要)
# Ali_Key=your_aliyun_key
# Ali_Secret=your_aliyun_secret

# Cloudflare 配置 (DNS_API=dns_cf 时需要)
# CF_Token=your_cloudflare_token

# 腾讯云配置 (DNS_API=dns_cx 时需要)
# CX_Key=your_tencent_cloud_key
# CX_Secret=your_tencent_cloud_secret

# ============================================
# 可选配置
# ============================================

# ACME 服务器 (letsencrypt / zerossl / buypass 等)
# ACME_SERVER=letsencrypt

# 续期阈值（天），剩余天数小于此值时自动续期
# RENEW_DAYS=7

# 检查间隔（秒），默认每天检查一次
# CHECK_INTERVAL=86400

# 七牛 CDN 实际域名（泛域名证书时需要指定）
# QINIU_CDN_DOMAIN=buildbuffer.cdn.zuoxueba.org
